{
  "name": "vow-marketing",
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not ie 11"
  ],
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:ai-sitemap": "node scripts/generate-ai-sitemap.mjs",
    "dev": "contentlayer2 dev & next dev",
    "build": "node scripts/generate-ai-sitemap.mjs && rm -rf .contentlayer && contentlayer2 build && next build",
    "build:analyze": "node scripts/generate-ai-sitemap.mjs && rm -rf .contentlayer && contentlayer2 build && ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@getbrevo/brevo": "^4.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/react": "^3.1.1",
    "@supabase/supabase-js": "^2.95.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "lucide-react": "^0.563.0",
    "next": "16.2.1",
    "next-contentlayer2": "^0.5.8",
    "nodemailer": "^6.10.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
